# OpenHive Configuration
# Copy this file to .env.local and fill in your values
# Or use the setup wizard at http://localhost:3000/setup

# ---- Supabase (required) ----
# Get these from: Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ---- LiveKit (optional — for video/audio calls) ----
# Get these from: cloud.livekit.io or your self-hosted LiveKit server
# Note: LiveKit credentials are configured per-workspace in the admin settings UI,
# not here. These env vars are only needed if you want a global default.
# LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_API_KEY=your-api-key
# LIVEKIT_API_SECRET=your-api-secret
